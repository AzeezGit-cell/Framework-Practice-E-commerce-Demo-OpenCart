<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Suite">

	<listeners>
		<listener class-name="utilities.ExtentListener" />
		<listener class-name="utilities.AnnotationTransformer"/>
	</listeners>
	<test name="RegressionTests">

		<parameter name="browser" value="chrome" />
		<parameter name="os" value="windows"></parameter>

		<groups>
			<run>
				<include name="regression" />
			</run>
		</groups>

		<classes>
			<class name="test_cases.TC001_AccountRegistration" />
			<class name="test_cases.TC002_LoginPage" />
			<class name="test_cases.TC003_LoginDDT" />
		</classes>

	</test>

</suite>